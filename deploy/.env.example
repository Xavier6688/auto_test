# =============================================================================
# Auto Test Platform - 环境变量配置
# 使用方式: cp .env.example .env && 按需修改
# =============================================================================

# ===== 数据库 (PostgreSQL) =====
POSTGRES_USER=autotest
POSTGRES_PASSWORD=autotest_dev
POSTGRES_DB=autotest

# ===== 缓存 (Redis) =====
REDIS_PASSWORD=autotest_dev

# ===== 消息队列 (RabbitMQ) =====
RABBITMQ_DEFAULT_USER=autotest
RABBITMQ_DEFAULT_PASS=autotest_dev

# ===== 对象存储 (MinIO) =====
MINIO_ROOT_USER=autotest
MINIO_ROOT_PASSWORD=autotest_dev

# ===== JWT =====
JWT_SECRET=dev_jwt_secret_change_in_prod_at_least_32_chars

# ===== AI/LLM =====
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o
# LLM_API_BASE_URL=          # 如使用代理或本地模型，取消注释并填写

# ===== JIRA（可选）=====
# JIRA_URL=https://your-org.atlassian.net
# JIRA_USER=your-email@example.com
# JIRA_TOKEN=your_jira_api_token

# ===== 通知（可选）=====
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
